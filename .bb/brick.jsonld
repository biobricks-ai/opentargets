  "@id": "https://brickyard.biobricks.ai/brick/opentargets",
  "agenticPriority": 2,
  "agenticPriorityLabel": "low",
  "dcterms:description": "The opentargets BioBrick contains data extracted from the Open Targets Platform, encompassing target-disease associations, drug-target interactions, and related evidence. This dataset includes information on drug warnings, gene expression, mouse phenotypes, and literature-mined associations, enabling applications in drug discovery, toxicology, and target validation.",
  "tables": {
    "drug_warning": {
      "@type": "csvw:Table",
      "@id": "https://brickyard.biobricks.ai/brick/opentargets/table/drug_warning",
      "dcterms:description": "The `drug_warning` table from Open Targets contains drug safety information, specifically warnings associated with drugs (identified by ChEMBL IDs), including the type of warning, affected country, year issued, and a description of the toxicity. It also links these warnings to Experimental Factor Ontology (EFO) terms to classify the affected biological processes or diseases.",
      "tableSchema": {
        "@type": "csvw:Schema",
        "columnCount": 11,
        "columns": [
          {
            "@type": "csvw:Column",
            "columnName": "chemblIds",
            "datatype": "List(String)",
            "dcterms:description": "A list of ChEMBL IDs associated with the drug warning.",
            "nullCount": 0,
            "uniqueCount": 85,
            "sampleValues": [
              "['CHEMBL4303288', 'CHEMBL1380']",
              "['CHEMBL16073']",
              "['CHEMBL4303288', 'CHEMBL1380']",
              "['CHEMBL1419']",
              "['CHEMBL1252']"
            ]
          },
          {
            "@type": "csvw:Column",
            "columnName": "toxicityClass",
            "datatype": "String",
            "dcterms:description": "The class of toxicity associated with the drug warning, such as hepatotoxicity or nephrotoxicity.",
            "nullCount": 12,
            "uniqueCount": 16,
            "sampleValues": [
              "hepatotoxicity",
              "nephrotoxicity",
              "immune system toxicity",
              "cardiotoxicity",
              "hepatotoxicity"
            ],
