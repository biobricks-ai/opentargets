            ]
          },
          {
            "@type": "csvw:Column",
            "columnName": "country",
            "datatype": "String",
            "dcterms:description": "The country or countries where the drug warning was issued.",
            "nullCount": 0,
            "uniqueCount": 21,
            "sampleValues": [
              "United States",
              "Malaysia; Romania; Germany; Ireland; Panama; Italy; Finland; New Zealand; Ethiopia; Greece; Yemen; C",
              "United States",
              "Indonesia; Egypt; Guatemala; Australia",
              "United States"
            ],
            "uniqueValues": [
              "Germany; European Union; Ireland; United Kingdom; ",
              "Oman",
              "France; Italy; Cuba; Chad",
              "France; United States; United Kingdom; Germany",
              "Germany; Worldwide; Spain; United Kingdom",
              "Malaysia; Romania; Germany; Ireland; Panama; Italy",
              "Indonesia; Egypt; Guatemala; Australia",
              "United States",
              "European Union",
              "France; Spain; Germany"
            ]
          },
          {
            "@type": "csvw:Column",
            "columnName": "description",
            "datatype": "String",
            "dcterms:description": "A textual description of the drug warning.",
            "nullCount": 69,
            "uniqueCount": 30,
            "sampleValues": [
              "Nephropathy",
              "Higher rate of cardiovascular events in obese and overweight patients using sibutramine than in pati",
              "Hepatoxicity",
              "Hepatotoxicity",
              "occurrence of bronchospasm"
            ]
          },
          {
            "@type": "csvw:Column",
            "columnName": "id",
            "datatype": "Int64",
            "dcterms:description": "A unique identifier for the drug warning entry.",
            "nullCount": 0,
            "uniqueCount": 100,
            "sampleValues": [
              "1",
              "3574",
              "3",
              "3578",
              "5"
            ]
          },
          {
            "@type": "csvw:Column",
            "columnName": "references",
            "datatype": "List(Struct({'ref_id': String, 'ref_type': String, 'ref_url': String}))",
            "dcterms:description": "A list of references supporting the drug warning, including ID, type, and URL.",
            "nullCount": 0,
            "uniqueCount": 70,
            "sampleValues": [
              "[{'ref_id': 'de109a2b-e36c-40d0-85fc-a67a9e7f1ae8', 'ref_type': 'DailyMed', 'ref_url': 'https://dail",
