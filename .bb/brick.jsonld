              "[{'efo_code': 'CL_0000890', 'label': 'alternatively activated macrophage', 'organs': ['immune organ'",
              "[{'efo_code': 'UBERON_0001873', 'label': 'caudate nucleus', 'organs': ['brain'], 'anatomical_systems",
              "[{'efo_code': 'UBERON_0002245', 'label': 'cerebellar hemisphere', 'organs': ['brain'], 'anatomical_s"
            ]
          }
        ],
        "rowCountSample": 100
      }
    },
    "drug_molecule": {
