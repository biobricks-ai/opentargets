      "@id": "https://brickyard.biobricks.ai/brick/opentargets/table/drug_molecule",
      "dcterms:description": "This table contains chemical properties and metadata for drug molecules, including identifiers, chemical structure representations (SMILES, InchiKey), approval status, clinical trial phase, and links to related diseases and targets. It provides a comprehensive overview of drug characteristics and relationships within the Open Targets Platform.",
      "tableSchema": {
        "@type": "csvw:Schema",
        "columnCount": 18,
        "columns": [
          {
            "@type": "csvw:Column",
            "columnName": "id",
