    "colocalisation_ecaviar": {
      "@type": "csvw:Table",
      "@id": "https://brickyard.biobricks.ai/brick/opentargets/table/colocalisation_ecaviar",
      "dcterms:description": "This table contains colocalization analysis results, specifically eCAVIAR results, between pairs of study-locus associations from Open Targets. It includes metrics such as CLPP, number of colocalizing variants, and beta ratio sign average, indicating the strength and direction of colocalization.",
      "tableSchema": {
        "@type": "csvw:Schema",
        "columnCount": 8,
        "columns": [
          {
            "@type": "csvw:Column",
            "columnName": "leftStudyLocusId",
            "datatype": "String",
            "dcterms:description": "A unique identifier for the left study locus involved in the colocalization analysis.",
            "nullCount": 0,
            "uniqueCount": 88,
            "sampleValues": [
              "000d05393cd5863b3ae6558178928554",
              "000d24cc7709a9f40d92ef85d1f75606",
